[importlinter]
root_packages =
    contracts
    swimcore
    persistence
    simulator
    swimtools
include_external_packages = True

[importlinter:contract:1]
name = Layered architecture (swimtools > simulator > persistence > swimcore > contracts)
type = layers
layers =
    swimtools
    simulator
    persistence
    swimcore
    contracts

[importlinter:contract:2]
name = swimcore must not import external-data plan contracts
type = forbidden
source_modules =
    swimcore
forbidden_modules =
    contracts.external_data

[importlinter:contract:3]
name = contracts must not import inner packages
type = forbidden
source_modules =
    contracts
forbidden_modules =
    swimcore
    persistence
    simulator
    swimtools

[importlinter:contract:4]
name = swimcore and contracts must not import IO frameworks
type = forbidden
source_modules =
    swimcore
    contracts
forbidden_modules =
    fastapi
    sqlalchemy
    sqlite3
    socket
    requests
    httpx
