[importlinter]
root_packages =
    contracts
    swimcore
    persistence
    analytics
    e2e
    simulator
    swimtools
include_external_packages = True

[importlinter:contract:1]
name = Layered architecture (swimtools > e2e > simulator > analytics > persistence > swimcore > contracts)
type = layers
layers =
    swimtools
    e2e
    simulator
    analytics
    persistence
    swimcore
    contracts

[importlinter:contract:2]
name = swimcore must not import external-data plan contracts
type = forbidden
source_modules =
    swimcore
forbidden_modules =
    contracts.external_data

[importlinter:contract:3]
name = contracts must not import inner packages
type = forbidden
source_modules =
    contracts
forbidden_modules =
    swimcore
    persistence
    analytics
    simulator
    swimtools

[importlinter:contract:4]
name = swimcore and contracts must not import IO frameworks
type = forbidden
source_modules =
    swimcore
    contracts
forbidden_modules =
    fastapi
    sqlalchemy
    sqlite3
    socket
    requests
    httpx

[importlinter:contract:5]
name = control must not depend on session
type = forbidden
source_modules =
    swimcore.control
forbidden_modules =
    swimcore.session

[importlinter:contract:6]
name = swimcore must not import dataset-asset or forecasting plan contracts
type = forbidden
source_modules =
    swimcore
forbidden_modules =
    contracts.data_assets
    contracts.forecasting

[importlinter:contract:7]
name = runtime layers must not depend on pandas/NumPy
type = forbidden
source_modules =
    contracts
    swimcore
    persistence
    analytics
    simulator
forbidden_modules =
    pandas
    numpy
    scipy

[importlinter:contract:8]
name = simulator must not read dataset catalogs or raw datasets
type = forbidden
source_modules =
    simulator
forbidden_modules =
    contracts.data_assets
    swimtools.data_catalog
    swimtools.validate_dataset_bundle
    swimtools.data_splitting

[importlinter:contract:9]
name = analytics must not depend on simulator persistence or swimtools
type = forbidden
source_modules =
    analytics
forbidden_modules =
    simulator
    persistence
    swimtools

[importlinter:contract:10]
name = swimcore and contracts must not import analytics
type = forbidden
source_modules =
    swimcore
    contracts
forbidden_modules =
    analytics

[importlinter:contract:11]
name = inner layers must not import the e2e verification layer
type = forbidden
source_modules =
    contracts
    swimcore
    persistence
    analytics
    simulator
forbidden_modules =
    e2e

[importlinter:contract:12]
name = e2e must not depend on swimtools or introduce nondeterminism
type = forbidden
source_modules =
    e2e
forbidden_modules =
    swimtools
    random
    secrets
    uuid
    socket
    requests
    httpx
    pandas
    numpy
